{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dev (npm via cmd — bypasses PS execution policy)",
      "type": "shell",
      "command": "npm run dev",
      "windows": {
        "command": "npm.cmd run dev",
        "options": {
          "shell": {
            "executable": "cmd.exe",
            "args": ["/d", "/c"]
          }
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
